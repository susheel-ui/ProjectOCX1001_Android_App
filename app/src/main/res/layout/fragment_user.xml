<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".WalletActivity">

    <!-- ================= TOP HEADER ================= -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_layout"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:background="@drawable/bg_bottom_rounded_40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Account Details"
            android:textColor="@android:color/black"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ================= SCROLL CONTENT ================= -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/header_layout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">



            <!-- ================= NAME + EDIT ================= -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/userNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile Details"
                    android:textColor="#111111"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:text="Edit"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textColor="@android:color/black"
                    android:backgroundTint="@color/color_primary"
                    app:cornerRadius="20dp"
                    android:elevation="4dp"/>
            </RelativeLayout>


            <!-- ================= FIRST NAME ================= -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@android:color/white">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="FIRST NAME"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/firstNameValue"
                        android:text=""
                        android:textSize="16sp"
                        android:textColor="#111111"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <!-- ================= LAST NAME ================= -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@android:color/white">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="LAST NAME"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/lastNameValue"
                        android:text=""
                        android:textSize="16sp"
                        android:textColor="#111111"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <!-- ================= EMAIL ================= -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@android:color/white">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="EMAIL"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/emailText"
                        android:text=""
                        android:textSize="16sp"
                        android:textColor="#111111"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <!-- ================= PHONE ================= -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@android:color/white">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="PHONE NUMBER"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/mobileText"
                        android:text=""
                        android:textSize="16sp"
                        android:textColor="#111111"/>
                </LinearLayout>


            </com.google.android.material.card.MaterialCardView>


            <!-- ================= Address ================= -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@android:color/white">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Address"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/addressText"
                        android:text=""
                        android:textSize="16sp"
                        android:textColor="#111111"/>
                </LinearLayout>


            </com.google.android.material.card.MaterialCardView>

            <!-- ================= GST  ================= -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@android:color/white">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="GST"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/gstText"
                        android:text=""
                        android:textSize="16sp"
                        android:textColor="#111111"/>
                </LinearLayout>


            </com.google.android.material.card.MaterialCardView>





            <!-- ================= LOGOUT ================= -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/logoutButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Logout"
                android:layout_marginTop="16dp"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/color_primary"
                android:textColor="@android:color/black"
                app:cornerRadius="16dp"/>

            <!-- Footer Section -->
            <LinearLayout
                android:id="@+id/footerLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:paddingBottom="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Terms and Policies -->
                <TextView
                    android:id="@+id/tvTermsPolicies"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Terms &amp; Conditions • Privacy Policy • About Us"
                    android:textSize="13sp"
                    android:textColor="@color/blue"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="6dp"
                    android:layout_marginBottom="4dp" />

                <!-- Version Info -->
                <TextView
                    android:id="@+id/tvVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zarkit • v0.0.1 \n© 2026 Zarkit Group Pvt Ltd. All rights reserved."
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:lineSpacingExtra="2dp"
                    android:gravity="center" />

            </LinearLayout>

        </LinearLayout>


    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>