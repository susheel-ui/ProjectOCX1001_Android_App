<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- ===== MAP (full screen base) ===== -->
    <fragment
        android:id="@+id/mapFragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===== PICKUP PIN ===== -->
    <ImageView
        android:id="@+id/pickupPin"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:src="@drawable/ic_location_on_green"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/mapFragment"
        app:layout_constraintBottom_toBottomOf="@id/mapFragment"
        app:layout_constraintStart_toStartOf="@id/mapFragment"
        app:layout_constraintEnd_toEndOf="@id/mapFragment" />

    <!-- ===== DROP PIN ===== -->
    <ImageView
        android:id="@+id/dropPin"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:src="@drawable/ic_location_on_red"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/mapFragment"
        app:layout_constraintBottom_toBottomOf="@id/mapFragment"
        app:layout_constraintStart_toStartOf="@id/mapFragment"
        app:layout_constraintEnd_toEndOf="@id/mapFragment" />

    <!-- ===== BACK BUTTON (top left) ===== -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/baseline_arrow_back_ios_24"
        android:background="@android:color/transparent"
        android:padding="6dp"
        android:elevation="12dp"
        android:scaleType="fitCenter"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ===== HELP BUTTON (top right) ===== -->

    <!-- ===== PICKUP + DROP CARD ===== -->
    <ImageView
        android:id="@+id/btnHelp"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:visibility="gone"
        android:layout_marginTop="220dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/circle_white_elevated"
        android:elevation="12dp"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_help_outline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#1A1A2E" />

    <androidx.cardview.widget.CardView
        android:id="@+id/searchContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:elevation="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== PICKUP ROW ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <!-- Green Pin Icon -->
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_location_on_green"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="12dp" />

                <!-- Pickup Text -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pickup Location"
                        android:textColor="#27AE60"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/pickupEdit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:focusable="false"
                        android:hint="Search pickup location"
                        android:textColorHint="#BBBBCC"
                        android:textColor="#1A1A2E"
                        android:textSize="14sp"
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:paddingStart="0dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="0dp" />
                </LinearLayout>

                <!-- Clear Pickup -->
                <ImageView
                    android:id="@+id/btnClearPickup"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:padding="4dp"
                    android:layout_marginStart="8dp"
                    app:tint="#AAAAAA" />
            </LinearLayout>

            <!-- DIVIDER -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginStart="58dp" />

            <!-- ===== DROP ROW ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <!-- Red Pin Icon -->
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_location_on_red"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="12dp" />

                <!-- Drop Text -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Drop Location"
                        android:textColor="#E53935"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/dropEdit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:focusable="false"
                        android:hint="Search drop location"
                        android:textColorHint="#BBBBCC"
                        android:textColor="#1A1A2E"
                        android:textSize="14sp"
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:paddingStart="0dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="0dp" />
                </LinearLayout>

                <!-- Clear Drop -->
                <ImageView
                    android:id="@+id/btnClearDrop"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:padding="4dp"
                    android:layout_marginStart="8dp"
                    app:tint="#AAAAAA" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ===== TOOLTIP CARD (shown by default, hide via code) ===== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/tooltipCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="100dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:elevation="20dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/searchContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Close button row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Bulb + Main tip -->
                <TextView
                    android:id="@+id/helpText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💡 ऊपर हरे रंग में जहाँ से सामान उठाना है और लाल रंग में जहाँ सामान पहुँचाना है, वह जगह चुनें।"
                    android:textSize="13sp"
                    android:textColor="#1A1A2E"
                    android:lineSpacingMultiplier="1.3" />

                <ImageView
                    android:id="@+id/btnCloseTooltip"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:layout_marginStart="8dp"
                    app:tint="#888888" />
            </LinearLayout>

            <!-- Info box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/tooltip_info_bg"
                android:padding="10dp"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="ℹ️"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ऊपर सामान उठाने की जगह या सामान पहुँचाने की जगह पर क्लिक करें। फिर मैप में दिख रहे लोकेशन चिन्ह को खींचकर, घुमाकर या ज़ूम करके सही जगह चुन सकते हैं।"
                    android:textSize="14sp"
                    android:textColor="#4A4A6A"
                    android:lineSpacingMultiplier="1.3" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ===== CONFIRM BUTTON ===== -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp"
        android:text="Confirm Locations"
        android:textColor="#1A1A2E"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/color_primary"
        app:cornerRadius="16dp"
        app:rippleColor="#40000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>