<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FB">

    <!-- ===== MAP ===== -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ===== TOP HEADER ===== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/topHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="14dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <!-- Back -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/circle_bg_gray"
                android:src="@drawable/baseline_arrow_back_ios_24"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:contentDescription="Back" />

            <!-- Ride ID center -->
            <TextView
                android:id="@+id/tvRideId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Ride ID: #A12345"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <!-- Help -->
            <ImageButton
                android:id="@+id/btnHelp"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/circle_bg_gray"
                android:src="@drawable/user"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:contentDescription="Help" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ===== BOTTOM DRIVER CARD ===== -->
    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Drag Handle -->
            <View
                android:layout_width="36dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:background="#DEDEDE"
                android:layout_marginBottom="14dp" />

            <!-- ===== DRIVER ROW ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Vehicle Image -->
                <ImageView
                    android:id="@+id/imgVehicleType"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/circle_bg_gray"
                    android:layout_marginEnd="14dp" />

                <!-- Driver Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/driverName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Robert Fox"
                        android:textColor="#1A1A2E"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvRideStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status: En Route"
                        android:textColor="#27AE60"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/tvVehicleNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MH12 AB 1234"
                        android:textColor="#4A4A6A"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:background="@drawable/chip_bg"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:id="@+id/tvFare"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fare: ₹0"
                        android:textColor="#1A1A2E"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />

                    <!-- Rating Row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_star" />

                        <TextView
                            android:id="@+id/driverRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="4.8"
                            android:textColor="#F59E0B"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPaymentStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Payment Done ✅"
                        android:textColor="#27AE60"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"
                        android:visibility="visible" />

                </LinearLayout>

                <!-- Call Button -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <ImageButton
                        android:id="@+id/btnCallDriver"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/circle_bg_green"
                        android:src="@drawable/img_1"
                        android:padding="12dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="Call Driver" />

                    <TextView
                        android:id="@+id/tvCallStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Connecting..."
                        android:textSize="9sp"
                        android:textColor="#E65100"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginTop="4dp"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F5"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="14dp" />

            <!-- PAY BUTTON -->
            <Button
                android:id="@+id/btnPay"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Pay Now"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#F2B934"
                android:stateListAnimator="@null"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- CANCEL BUTTON -->
            <Button
                android:id="@+id/btnCancelRide"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Cancel Ride"
                android:textColor="#E53935"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#FFEBEE"
                android:stateListAnimator="@null"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>