<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <!-- ================= TOP HEADER ================= -->
    <LinearLayout
        android:id="@+id/topHeader"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:background="@color/white"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/baseline_arrow_back_ios_24"
            android:contentDescription="Back"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Review Booking"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#111111"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="अपनी बुकिंग की समीक्षा करें"
                android:textSize="11sp"
                android:textColor="#888888"
                android:layout_marginTop="1dp"/>
        </LinearLayout>

        <!-- Spacer for balance -->
        <View
            android:layout_width="36dp"
            android:layout_height="36dp"/>

    </LinearLayout>

    <!-- ================= SCROLLABLE CONTENT ================= -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topHeader"
        app:layout_constraintBottom_toTopOf="@id/bottomSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp"
            android:background="#F0F2F5">

            <!-- ===== VEHICLE CARD ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:background="@drawable/white_card"
                android:elevation="2dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:id="@+id/vehicleImage"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/zarkitgroup"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_vehicle_icon_box"
                    android:padding="4dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/vehicleName"
                        android:text="2 Wheeler"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#111111"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/addressDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View Address Details"
                        android:textColor="#1A6FE0"
                        android:textSize="10sp"
                        android:layout_marginTop="3dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"/>
                </LinearLayout>

                <!-- Electric Badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ Faster Delivery"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#0A7A45"
                    android:background="@drawable/bg_badge_electric"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"/>

            </LinearLayout>

            <!-- ===== GOODS TYPE CARD ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:background="@drawable/white_card"
                android:elevation="2dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:text="Goods Type"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/goodsType"
                        android:text="General • Loose"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#111111"
                        android:layout_marginTop="2dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/btnChange"
                    android:text="Change ›"
                    android:textColor="#1A6FE0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="6dp"
                    android:clickable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- ===== WARNING CARD ===== -->
            <LinearLayout
                android:id="@+id/restrictedItemsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="13dp"
                android:background="@drawable/yellow_card"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡️"
                    android:textSize="20sp"
                    android:layout_marginEnd="10dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:text="Do not send restricted items"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#7A5700"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="प्रतिबंधित सामान की सूची देखने के लिए यहां क्लिक करें।"
                        android:textSize="11sp"
                        android:textColor="#A07800"
                        android:layout_marginTop="2dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/btnViewList"
                    android:text="View List ›"
                    android:textColor="#1A6FE0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:layout_marginStart="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- ===== TOTAL FARE CARD ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:background="@drawable/white_card"
                android:elevation="2dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏷️"
                    android:textSize="22sp"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Fare"
                        android:textSize="12sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:id="@+id/finalFareText"
                        android:text="₹30.00"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#111111"
                        android:layout_marginTop="1dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- GST Info Pill -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ⓘ 18% GST\nincluded"
                    android:textSize="11sp"
                    android:textColor="#555555"
                    android:gravity="center"
                    android:background="@drawable/bg_gst_pill"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"/>

            </LinearLayout>

            <!-- ===== READ BEFORE BOOKING ===== -->
            <TextView
                android:text="Read Before Booking"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#111111"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:id="@+id/rulesCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/white_card"
                android:elevation="2dp"
                android:orientation="vertical">

                <include
                    android:id="@+id/rule1"
                    layout="@layout/item_rule"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#EEEEEE"
                    android:layout_marginHorizontal="16dp"/>

                <include
                    android:id="@+id/rule2"
                    layout="@layout/item_rule"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#EEEEEE"
                    android:layout_marginHorizontal="16dp"/>

                <include
                    android:id="@+id/rule3"
                    layout="@layout/item_rule"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#EEEEEE"
                    android:layout_marginHorizontal="16dp"/>

                <include
                    android:id="@+id/rule4"
                    layout="@layout/item_rule"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#EEEEEE"
                    android:layout_marginHorizontal="16dp"/>

                <include
                    android:id="@+id/rule5"
                    layout="@layout/item_rule"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#EEEEEE"
                    android:layout_marginHorizontal="16dp"/>

                <include
                    android:id="@+id/rule6"
                    layout="@layout/item_rule"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#EEEEEE"
                    android:layout_marginHorizontal="16dp"/>

                <include
                    android:id="@+id/rule7"
                    layout="@layout/item_rule"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ================= BOTTOM SECTION ================= -->
    <LinearLayout
        android:id="@+id/bottomSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- GST BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0C3A9C"
            android:padding="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛡️"
                android:textSize="18sp"
                android:layout_marginEnd="8dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:text="18% GST included in final fare"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Add or remove GST from your booking."
                    android:textColor="#B3C6FF"
                    android:textSize="11sp"
                    android:layout_marginTop="1dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <TextView
                android:id="@+id/btnAddGstTop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add GST"
                android:textColor="#0C3A9C"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="7dp"
                android:background="@drawable/bg_gst_button"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- PAYMENT ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/payment_card_bg"
            android:elevation="3dp"
            android:padding="14dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="10dp"
            android:foreground="?attr/selectableItemBackground">

            <!-- Payment Icon -->
            <LinearLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/payment_icon_bg"
                android:gravity="center"
                android:layout_marginEnd="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💵"
                    android:textSize="20sp"/>
            </LinearLayout>

            <!-- Payment Title -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Choose Payment Method"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#111111"/>

                <TextView
                    android:id="@+id/paymentMethod"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cash Payment"
                    android:textSize="12sp"
                    android:textColor="#777777"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Fare Section -->
            <LinearLayout
                android:id="@+id/fareDetailsLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:background="@drawable/fare_bg"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <TextView
                    android:id="@+id/paymentFare"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹30.00"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#111111"/>

                <TextView
                    android:id="@+id/priceInfoIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginStart="5dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- CONFIRM BUTTON -->
        <Button
            android:id="@+id/bookNowButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:textColor="#1A1200"
            android:text="🔒  Confirm and Proceed"
            android:textStyle="bold"
            android:textSize="15sp"
            android:backgroundTint="#F5C518"
            android:elevation="4dp"
            android:layout_margin="14dp"
            android:stateListAnimator="@null"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>